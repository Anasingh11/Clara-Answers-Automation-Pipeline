# Clara Pipeline Configuration
# Copy this file to .env and adjust as needed

# Directories (defaults work out of the box)
DATA_DIR=./data
OUTPUT_DIR=./outputs

# n8n webhook URL (optional — only needed if triggering via n8n)
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Retell API key (optional — pipeline produces spec JSON; key needed only for live import)
RETELL_API_KEY=

# Dashboard port
DASHBOARD_PORT=3000
